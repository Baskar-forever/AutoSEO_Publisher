# --- LLM API Configuration ---
# Your OpenAI API key (or Google Gemini API key if using Gemini via LiteLLM)
OPENAI_API_KEY="your_api_key_here"

# The LLM model you want to use (e.g., "gpt-4o", "gemini/gemini-2.5-flash")
MODEL="gemini/gemini-2.5-flash"

# --- Search & Tools Configuration ---
# Serper.dev API key for Google Search and Google Images scraping
SERPER_API_KEY="your_serper_api_key_here"

# --- WordPress Configuration ---
# The base URL of your WordPress website 
WP_URL="https://readtechflow.com/"

# Your WordPress username or admin email address
WP_USER="your_wp_username"

# Application Password generated from WordPress Users profile (NOT your normal login password)
WP_APP_PASSWORD="your_wp_application_password_here"
